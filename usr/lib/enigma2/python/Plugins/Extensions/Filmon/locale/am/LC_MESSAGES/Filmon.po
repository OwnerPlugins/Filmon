msgid "Buffering..."
msgstr "በማቋት ላይ..."

msgid "Cancel"
msgstr "ሰርዝ"

msgid "Cannot find group ID"
msgstr "የቡድን መታወቂያ ማግኘት አልተቻለም"

msgid "Cannot regenerate stream URL"
msgstr "የዥረት ዩአርኤልን እንደገና ማመንጨት አልተቻለም"

msgid "Cannot restore stream connection"
msgstr "የዥረት ግንኙነትን ወደነበረበት መመለስ አልተቻለም"

msgid "Could not get stream token"
msgstr "የዥረት ማስመሰያ ማግኘት አልተቻለም"

msgid "Enable Token Update refresh on Player."
msgstr "በተጫዋች ላይ ማስመሰያ ማደስን አንቃ።"

msgid "Enable token auto-refresh"
msgstr "ማስመሰያ በራስ-አድስን አንቃ"

msgid "Error loading channels"
msgstr "ቻናሎችን መጫን ላይ ስህተት"

msgid "Exit"
msgstr "ውጣ"

msgid "Filmon Settings"
msgstr "የፊልም ቅንጅቶች"

msgid "Maximum reconnection attempts reached"
msgstr "ከፍተኛው የመልሶ ማገናኘት ሙከራዎች ደርሰዋል"

msgid "No channels found"
msgstr "ምንም ሰርጦች አልተገኙም።"

msgid "OK"
msgstr "እሺ"

msgid "Play/pause not supported for this stream"
msgstr "ለዚህ ዥረት መጫወት/አፍታ ማቆም አይደገፍም።"

msgid "Select stream quality"
msgstr "የዥረት ጥራት ይምረጡ"

msgid "Session error, try again later ..."
msgstr "የክፍለ ጊዜው ስህተት፣ ቆይተው እንደገና ይሞክሩ..."

msgid "Set Timer Refresh update Player."
msgstr "የሰዓት ቆጣሪ እድሳት ማጫወቻን ያዘጋጁ።"

msgid "Token refresh interval (seconds)"
msgstr "የማስመሰያ እድሳት ክፍተት (ሰከንዶች)"

msgid "Try again later ..."
msgstr "ቆይተው እንደገና ይሞክሩ..."

msgid "WELCOME TO FILMON PLUGIN BY LULULLA"
msgstr "እንኳን በደህና መጡ ወደ የፊልም ፕላግ በሉሉላ"
