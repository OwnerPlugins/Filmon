msgid "Buffering..."
msgstr "جارٍ التخزين المؤقت..."

msgid "Cancel"
msgstr "يلغي"

msgid "Cannot find group ID"
msgstr "لا يمكن العثور على معرف المجموعة"

msgid "Cannot regenerate stream URL"
msgstr "لا يمكن إعادة إنشاء عنوان URL للبث"

msgid "Cannot restore stream connection"
msgstr "لا يمكن استعادة اتصال الدفق"

msgid "Could not get stream token"
msgstr "تعذر الحصول على رمز البث"

msgid "Enable Token Update refresh on Player."
msgstr "تمكين تحديث الرمز المميز على المشغل."

msgid "Enable token auto-refresh"
msgstr "تمكين التحديث التلقائي للرمز المميز"

msgid "Error loading channels"
msgstr "حدث خطأ أثناء تحميل القنوات"

msgid "Exit"
msgstr "مخرج"

msgid "Filmon Settings"
msgstr "إعدادات فيلمون"

msgid "Maximum reconnection attempts reached"
msgstr "تم الوصول إلى الحد الأقصى لمحاولات إعادة الاتصال"

msgid "No channels found"
msgstr "لم يتم العثور على قنوات"

msgid "OK"
msgstr "نعم"

msgid "Play/pause not supported for this stream"
msgstr "التشغيل/الإيقاف المؤقت غير مدعوم لهذا الدفق"

msgid "Select stream quality"
msgstr "حدد جودة البث"

msgid "Session error, try again later ..."
msgstr "حدث خطأ في الجلسة، حاول مرة أخرى لاحقًا..."

msgid "Set Timer Refresh update Player."
msgstr "ضبط تحديث مؤقت للمشغل."

msgid "Token refresh interval (seconds)"
msgstr "الفاصل الزمني لتحديث الرمز المميز (بالثواني)"

msgid "Try again later ..."
msgstr "حاول مرة أخرى لاحقا..."

msgid "WELCOME TO FILMON PLUGIN BY LULULLA"
msgstr "مرحبًا بك في برنامج FILMON الإضافي من LULULLA"
