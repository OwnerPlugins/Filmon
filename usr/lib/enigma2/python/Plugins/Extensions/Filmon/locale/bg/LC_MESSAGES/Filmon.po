msgid "Buffering..."
msgstr "Буфериране..."

msgid "Cancel"
msgstr "Отказ"

msgid "Cannot find group ID"
msgstr "Не може да се намери идентификатор на група"

msgid "Cannot regenerate stream URL"
msgstr "URL адресът на потока не може да се генерира повторно"

msgid "Cannot restore stream connection"
msgstr "Връзката за поток не може да се възстанови"

msgid "Could not get stream token"
msgstr "Не можа да се получи токен за поток"

msgid "Enable Token Update refresh on Player."
msgstr "Активиране на опресняването на Token Update в Player."

msgid "Enable token auto-refresh"
msgstr "Активирайте автоматичното опресняване на токена"

msgid "Error loading channels"
msgstr "Грешка при зареждането на каналите"

msgid "Exit"
msgstr "Изход"

msgid "Filmon Settings"
msgstr "Настройки на Filmon"

msgid "Maximum reconnection attempts reached"
msgstr "Достигнат е максимален брой опити за повторно свързване"

msgid "No channels found"
msgstr "Няма намерени канали"

msgid "OK"
msgstr "добре"

msgid "Play/pause not supported for this stream"
msgstr "Пускане/пауза не се поддържа за този поток"

msgid "Select stream quality"
msgstr "Изберете качество на потока"

msgid "Session error, try again later ..."
msgstr "Грешка в сесията, опитайте отново по-късно..."

msgid "Set Timer Refresh update Player."
msgstr "Задаване на обновяване на таймера актуализиране на плейъра."

msgid "Token refresh interval (seconds)"
msgstr "Интервал за опресняване на токена (секунди)"

msgid "Try again later ..."
msgstr "Опитайте отново по-късно..."

msgid "WELCOME TO FILMON PLUGIN BY LULULLA"
msgstr "ДОБРЕ ДОШЛИ В ПЛУГИНА FILMON ОТ LULULLA"
