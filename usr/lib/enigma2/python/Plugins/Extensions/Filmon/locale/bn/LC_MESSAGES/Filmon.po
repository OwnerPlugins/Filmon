msgid "Buffering..."
msgstr "বাফারিং..."

msgid "Cancel"
msgstr "বাতিল করুন"

msgid "Cannot find group ID"
msgstr "গ্রুপ আইডি খুঁজে পাচ্ছি না"

msgid "Cannot regenerate stream URL"
msgstr "স্ট্রীম URL পুনরায় তৈরি করা যাবে না"

msgid "Cannot restore stream connection"
msgstr "স্ট্রিম সংযোগ পুনরুদ্ধার করা যাবে না৷"

msgid "Could not get stream token"
msgstr "স্ট্রিম টোকেন পাওয়া যায়নি"

msgid "Enable Token Update refresh on Player."
msgstr "প্লেয়ারে টোকেন আপডেট রিফ্রেশ সক্ষম করুন।"

msgid "Enable token auto-refresh"
msgstr "টোকেন স্বয়ংক্রিয়-রিফ্রেশ সক্ষম করুন"

msgid "Error loading channels"
msgstr "চ্যানেল লোড করার সময় ত্রুটি৷"

msgid "Exit"
msgstr "প্রস্থান করুন"

msgid "Filmon Settings"
msgstr "ফিল্মন সেটিংস"

msgid "Maximum reconnection attempts reached"
msgstr "সর্বাধিক পুনঃসংযোগ প্রচেষ্টা পৌঁছেছে"

msgid "No channels found"
msgstr "কোনো চ্যানেল পাওয়া যায়নি"

msgid "OK"
msgstr "ঠিক আছে"

msgid "Play/pause not supported for this stream"
msgstr "এই স্ট্রীমের জন্য প্লে/পজ সমর্থিত নয়"

msgid "Select stream quality"
msgstr "স্ট্রিম গুণমান নির্বাচন করুন"

msgid "Session error, try again later ..."
msgstr "সেশন ত্রুটি, পরে আবার চেষ্টা করুন..."

msgid "Set Timer Refresh update Player."
msgstr "টাইমার রিফ্রেশ আপডেট প্লেয়ার সেট করুন।"

msgid "Token refresh interval (seconds)"
msgstr "টোকেন রিফ্রেশ ব্যবধান (সেকেন্ড)"

msgid "Try again later ..."
msgstr "পরে আবার চেষ্টা করুন..."

msgid "WELCOME TO FILMON PLUGIN BY LULULLA"
msgstr "লুলুল্লার ফিলমন প্লাগইন-এ স্বাগতম"
