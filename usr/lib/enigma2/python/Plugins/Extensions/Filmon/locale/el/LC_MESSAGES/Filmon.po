msgid "Buffering..."
msgstr "Αποθήκευση…"

msgid "Cancel"
msgstr "Ματαίωση"

msgid "Cannot find group ID"
msgstr "Δεν είναι δυνατή η εύρεση του αναγνωριστικού ομάδας"

msgid "Cannot regenerate stream URL"
msgstr "Δεν είναι δυνατή η αναγέννηση της διεύθυνσης URL ροής"

msgid "Cannot restore stream connection"
msgstr "Δεν είναι δυνατή η επαναφορά της σύνδεσης ροής"

msgid "Could not get stream token"
msgstr "Δεν ήταν δυνατή η λήψη του διακριτικού ροής"

msgid "Enable Token Update refresh on Player."
msgstr "Ενεργοποιήστε την ανανέωση του Token Update στο Player."

msgid "Enable token auto-refresh"
msgstr "Ενεργοποίηση αυτόματης ανανέωσης διακριτικού"

msgid "Error loading channels"
msgstr "Σφάλμα κατά τη φόρτωση καναλιών"

msgid "Exit"
msgstr "Εξοδος"

msgid "Filmon Settings"
msgstr "Ρυθμίσεις Filmon"

msgid "Maximum reconnection attempts reached"
msgstr "Επιτεύχθηκαν οι μέγιστες προσπάθειες επανασύνδεσης"

msgid "No channels found"
msgstr "Δεν βρέθηκαν κανάλια"

msgid "OK"
msgstr "ΕΝΤΑΞΕΙ"

msgid "Play/pause not supported for this stream"
msgstr "Η αναπαραγωγή/παύση δεν υποστηρίζεται για αυτήν τη ροή"

msgid "Select stream quality"
msgstr "Επιλέξτε ποιότητα ροής"

msgid "Session error, try again later ..."
msgstr "Σφάλμα συνεδρίας, δοκιμάστε ξανά αργότερα..."

msgid "Set Timer Refresh update Player."
msgstr "Ρύθμιση προγράμματος αναπαραγωγής ενημέρωσης ανανέωσης χρονοδιακόπτη."

msgid "Token refresh interval (seconds)"
msgstr "Διάστημα ανανέωσης διακριτικού (δευτερόλεπτα)"

msgid "Try again later ..."
msgstr "Δοκιμάστε ξανά αργότερα..."

msgid "WELCOME TO FILMON PLUGIN BY LULULLA"
msgstr "ΚΑΛΩΣ ΟΡΙΣΑΤΕ ΣΤΟ FILMON PLUGIN BY LULULLA"
