msgid "Buffering..."
msgstr "بافر کردن..."

msgid "Cancel"
msgstr "لغو کنید"

msgid "Cannot find group ID"
msgstr "شناسه گروه پیدا نمی شود"

msgid "Cannot regenerate stream URL"
msgstr "نمی توان URL جریان را بازسازی کرد"

msgid "Cannot restore stream connection"
msgstr "اتصال جریان را نمی توان بازیابی کرد"

msgid "Could not get stream token"
msgstr "رمز پخش جریانی دریافت نشد"

msgid "Enable Token Update refresh on Player."
msgstr "به روز رسانی Token Update را در Player فعال کنید."

msgid "Enable token auto-refresh"
msgstr "بازخوانی خودکار نشانه را فعال کنید"

msgid "Error loading channels"
msgstr "خطا در بارگیری کانال ها"

msgid "Exit"
msgstr "خارج شوید"

msgid "Filmon Settings"
msgstr "تنظیمات Filmon"

msgid "Maximum reconnection attempts reached"
msgstr "به حداکثر تلاش برای اتصال مجدد رسیده است"

msgid "No channels found"
msgstr "کانالی پیدا نشد"

msgid "OK"
msgstr "باشه"

msgid "Play/pause not supported for this stream"
msgstr "پخش/مکث برای این جریان پشتیبانی نمی‌شود"

msgid "Select stream quality"
msgstr "کیفیت پخش را انتخاب کنید"

msgid "Session error, try again later ..."
msgstr "خطای جلسه، بعداً دوباره امتحان کنید..."

msgid "Set Timer Refresh update Player."
msgstr "پخش کننده به روز رسانی تایمر را تنظیم کنید."

msgid "Token refresh interval (seconds)"
msgstr "فاصله بازخوانی رمز (ثانیه)"

msgid "Try again later ..."
msgstr "بعدا دوباره امتحان کنید..."

msgid "WELCOME TO FILMON PLUGIN BY LULULLA"
msgstr "به پلاگین FILMON BY LULULLA خوش آمدید"
