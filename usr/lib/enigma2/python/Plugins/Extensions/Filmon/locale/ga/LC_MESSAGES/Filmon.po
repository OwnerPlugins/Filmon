msgid "Buffering..."
msgstr "Ag maolánú..."

msgid "Cancel"
msgstr "Cealaigh"

msgid "Cannot find group ID"
msgstr "Ní féidir aitheantas grúpa a aimsiú"

msgid "Cannot regenerate stream URL"
msgstr "Ní féidir URL an tsrutha a athghiniúint"

msgid "Cannot restore stream connection"
msgstr "Ní féidir an nasc srutha a chur ar ais"

msgid "Could not get stream token"
msgstr "Níorbh fhéidir comhartha an tsrutha a fháil"

msgid "Enable Token Update refresh on Player."
msgstr "Cumasaigh Token Update athnuachan ar Player."

msgid "Enable token auto-refresh"
msgstr "Cumasaigh uath-athnuachan comharthaí"

msgid "Error loading channels"
msgstr "Earráid agus cainéil á lódáil"

msgid "Exit"
msgstr "Scoir"

msgid "Filmon Settings"
msgstr "Socruithe Filmon"

msgid "Maximum reconnection attempts reached"
msgstr "Rinneadh uasiarrachtaí athcheangail"

msgid "No channels found"
msgstr "Níor aimsíodh aon chainéil"

msgid "OK"
msgstr "ceart go leor"

msgid "Play/pause not supported for this stream"
msgstr "Ní thacaítear le súgradh/sos don sruth seo"

msgid "Select stream quality"
msgstr "Roghnaigh cáilíocht sruth"

msgid "Session error, try again later ..."
msgstr "Earráid seisiúin, bain triail eile as ar ball..."

msgid "Set Timer Refresh update Player."
msgstr "Socraigh an t-imreoir nuashonraithe an t-amadóir."

msgid "Token refresh interval (seconds)"
msgstr "Eatramh athnuachana comhartha (soicindí)"

msgid "Try again later ..."
msgstr "Bain triail eile as ar ball..."

msgid "WELCOME TO FILMON PLUGIN BY LULULLA"
msgstr "FÁILTE CHUIG AN BHREISEÁN SCANNÁN Ó LULULLA"
