msgid "Buffering..."
msgstr "חציצה..."

msgid "Cancel"
msgstr "לְבַטֵל"

msgid "Cannot find group ID"
msgstr "לא ניתן למצוא מזהה קבוצה"

msgid "Cannot regenerate stream URL"
msgstr "לא ניתן ליצור מחדש את כתובת האתר של הזרם"

msgid "Cannot restore stream connection"
msgstr "לא ניתן לשחזר את חיבור הזרם"

msgid "Could not get stream token"
msgstr "לא ניתן היה לקבל אסימון סטרימינג"

msgid "Enable Token Update refresh on Player."
msgstr "אפשר רענון עדכון אסימון בנגן."

msgid "Enable token auto-refresh"
msgstr "אפשר רענון אוטומטי של אסימון"

msgid "Error loading channels"
msgstr "שגיאה בטעינת ערוצים"

msgid "Exit"
msgstr "יְצִיאָה"

msgid "Filmon Settings"
msgstr "הגדרות Filmon"

msgid "Maximum reconnection attempts reached"
msgstr "הגעתם לניסיונות חיבור מחדש מקסימליים"

msgid "No channels found"
msgstr "לא נמצאו ערוצים"

msgid "OK"
msgstr "בְּסֵדֶר"

msgid "Play/pause not supported for this stream"
msgstr "הפעלה/השהיה לא נתמכת עבור הזרם הזה"

msgid "Select stream quality"
msgstr "בחר איכות זרם"

msgid "Session error, try again later ..."
msgstr "שגיאת הפעלה, נסה שוב מאוחר יותר..."

msgid "Set Timer Refresh update Player."
msgstr "הגדר נגן עדכון טיימר רענון."

msgid "Token refresh interval (seconds)"
msgstr "מרווח רענון אסימון (שניות)"

msgid "Try again later ..."
msgstr "נסה שוב מאוחר יותר..."

msgid "WELCOME TO FILMON PLUGIN BY LULULLA"
msgstr "ברוכים הבאים ל-FILMON PLUGIN מאת LULULLA"
