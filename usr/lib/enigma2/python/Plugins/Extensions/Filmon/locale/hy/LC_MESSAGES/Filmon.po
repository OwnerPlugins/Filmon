msgid "Buffering..."
msgstr "Բուֆերացում..."

msgid "Cancel"
msgstr "Չեղարկել"

msgid "Cannot find group ID"
msgstr "Հնարավոր չէ գտնել խմբի ID"

msgid "Cannot regenerate stream URL"
msgstr "Հնարավոր չէ վերականգնել հոսքի URL-ը"

msgid "Cannot restore stream connection"
msgstr "Հնարավոր չէ վերականգնել հոսքային կապը"

msgid "Could not get stream token"
msgstr "Չհաջողվեց ստանալ հեռարձակման նշան"

msgid "Enable Token Update refresh on Player."
msgstr "Միացնել Token Update-ի թարմացումը Player-ում:"

msgid "Enable token auto-refresh"
msgstr "Միացնել նշանի ավտոմատ թարմացումը"

msgid "Error loading channels"
msgstr "Չհաջողվեց բեռնել ալիքները"

msgid "Exit"
msgstr "Ելք"

msgid "Filmon Settings"
msgstr "Ֆիլմոնի կարգավորումներ"

msgid "Maximum reconnection attempts reached"
msgstr "Վերամիացման առավելագույն փորձերը հասել են"

msgid "No channels found"
msgstr "Ալիքներ չեն գտնվել"

msgid "OK"
msgstr "Լավ"

msgid "Play/pause not supported for this stream"
msgstr "Նվագարկել/դադարեցնել այս հեռարձակումը չի աջակցվում"

msgid "Select stream quality"
msgstr "Ընտրեք հոսքի որակը"

msgid "Session error, try again later ..."
msgstr "Աշխատաշրջանի սխալ, փորձեք ավելի ուշ…"

msgid "Set Timer Refresh update Player."
msgstr "Սահմանեք ժմչփի թարմացման թարմացման նվագարկիչը:"

msgid "Token refresh interval (seconds)"
msgstr "Նշանների թարմացման ընդմիջում (վայրկյան)"

msgid "Try again later ..."
msgstr "Փորձեք ավելի ուշ…"

msgid "WELCOME TO FILMON PLUGIN BY LULULLA"
msgstr "ԲԱՐԻ ԳԱԼՈՒՍՏ FILMON PLUGIN BY LULULLA-ի կողմից"
