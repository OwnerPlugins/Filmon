msgid "Buffering..."
msgstr "ბუფერირება..."

msgid "Cancel"
msgstr "გაუქმება"

msgid "Cannot find group ID"
msgstr "ჯგუფის ID ვერ მოიძებნა"

msgid "Cannot regenerate stream URL"
msgstr "ნაკადის URL-ის რეგენერაცია შეუძლებელია"

msgid "Cannot restore stream connection"
msgstr "ნაკადის კავშირის აღდგენა შეუძლებელია"

msgid "Could not get stream token"
msgstr "ნაკადის ჟეტონი ვერ მივიღე"

msgid "Enable Token Update refresh on Player."
msgstr "ჩართეთ Token Update განახლება Player-ზე."

msgid "Enable token auto-refresh"
msgstr "ჩართეთ ტოკენის ავტომატური განახლება"

msgid "Error loading channels"
msgstr "შეცდომა არხების ჩატვირთვისას"

msgid "Exit"
msgstr "გასვლა"

msgid "Filmon Settings"
msgstr "Filmon პარამეტრები"

msgid "Maximum reconnection attempts reached"
msgstr "მიღწეულია ხელახალი დაკავშირების მაქსიმალური მცდელობა"

msgid "No channels found"
msgstr "არხები ვერ მოიძებნა"

msgid "OK"
msgstr ""

msgid "Play/pause not supported for this stream"
msgstr "დაკვრა/პაუზა არ არის მხარდაჭერილი ამ ნაკადისთვის"

msgid "Select stream quality"
msgstr "აირჩიეთ ნაკადის ხარისხი"

msgid "Session error, try again later ..."
msgstr "სესიის შეცდომა, სცადეთ მოგვიანებით..."

msgid "Set Timer Refresh update Player."
msgstr "დააყენეთ ტაიმერის განახლების განახლების პლეერი."

msgid "Token refresh interval (seconds)"
msgstr "ჟეტონის განახლების ინტერვალი (წამი)"

msgid "Try again later ..."
msgstr "სცადეთ მოგვიანებით..."

msgid "WELCOME TO FILMON PLUGIN BY LULULLA"
msgstr "კეთილი იყოს თქვენი მობრძანება FILMON PLUGIN BY LULULLA-ში"
