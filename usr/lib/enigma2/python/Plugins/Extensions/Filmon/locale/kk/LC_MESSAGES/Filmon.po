msgid "Set Timer Refresh update Player."
msgstr "Таймерді жаңартуды жаңарту ойнатқышын орнатыңыз."

msgid "Token refresh interval (seconds)"
msgstr "Токенді жаңарту аралығы (секунд)"

msgid "Try again later ..."
msgstr "Әрекетті кейінірек қайталаңыз..."

msgid "WELCOME TO FILMON PLUGIN BY LULULLA"
msgstr "LULULLA FILMON ПЛАГИНІНЕ ҚОШ КЕЛДІҢІЗ"
