msgid "Buffering..."
msgstr "ಬಫರಿಂಗ್..."

msgid "Cancel"
msgstr "ರದ್ದುಮಾಡಿ"

msgid "Cannot find group ID"
msgstr "ಗುಂಪು ID ಹುಡುಕಲಾಗಲಿಲ್ಲ"

msgid "Cannot regenerate stream URL"
msgstr "ಸ್ಟ್ರೀಮ್ URL ಅನ್ನು ಮರುಸೃಷ್ಟಿಸಲು ಸಾಧ್ಯವಿಲ್ಲ"

msgid "Cannot restore stream connection"
msgstr "ಸ್ಟ್ರೀಮ್ ಸಂಪರ್ಕವನ್ನು ಮರುಸ್ಥಾಪಿಸಲು ಸಾಧ್ಯವಿಲ್ಲ"

msgid "Could not get stream token"
msgstr "ಸ್ಟ್ರೀಮ್ ಟೋಕನ್ ಪಡೆಯಲು ಸಾಧ್ಯವಾಗಲಿಲ್ಲ"

msgid "Enable Token Update refresh on Player."
msgstr "ಪ್ಲೇಯರ್‌ನಲ್ಲಿ ಟೋಕನ್ ಅಪ್‌ಡೇಟ್ ರಿಫ್ರೆಶ್ ಅನ್ನು ಸಕ್ರಿಯಗೊಳಿಸಿ."

msgid "Enable token auto-refresh"
msgstr "ಟೋಕನ್ ಸ್ವಯಂ ರಿಫ್ರೆಶ್ ಅನ್ನು ಸಕ್ರಿಯಗೊಳಿಸಿ"

msgid "Error loading channels"
msgstr "ಚಾನಲ್‌ಗಳನ್ನು ಲೋಡ್ ಮಾಡುವಲ್ಲಿ ದೋಷ"

msgid "Exit"
msgstr "ನಿರ್ಗಮಿಸಿ"

msgid "Filmon Settings"
msgstr "ಫಿಲ್ಮನ್ ಸೆಟ್ಟಿಂಗ್‌ಗಳು"

msgid "Maximum reconnection attempts reached"
msgstr "ಗರಿಷ್ಠ ಮರುಸಂಪರ್ಕ ಪ್ರಯತ್ನಗಳನ್ನು ತಲುಪಿದೆ"

msgid "No channels found"
msgstr "ಯಾವುದೇ ಚಾನಲ್‌ಗಳು ಕಂಡುಬಂದಿಲ್ಲ"

msgid "OK"
msgstr "ಸರಿ"

msgid "Play/pause not supported for this stream"
msgstr "ಈ ಸ್ಟ್ರೀಮ್‌ಗೆ ಪ್ಲೇ/ವಿರಾಮ ಬೆಂಬಲವಿಲ್ಲ"

msgid "Select stream quality"
msgstr "ಸ್ಟ್ರೀಮ್ ಗುಣಮಟ್ಟವನ್ನು ಆಯ್ಕೆಮಾಡಿ"

msgid "Session error, try again later ..."
msgstr "ಸೆಷನ್ ದೋಷ, ನಂತರ ಮತ್ತೆ ಪ್ರಯತ್ನಿಸಿ..."

msgid "Set Timer Refresh update Player."
msgstr "ಟೈಮರ್ ರಿಫ್ರೆಶ್ ಅಪ್‌ಡೇಟ್ ಪ್ಲೇಯರ್ ಅನ್ನು ಹೊಂದಿಸಿ."

msgid "Token refresh interval (seconds)"
msgstr "ಟೋಕನ್ ರಿಫ್ರೆಶ್ ಮಧ್ಯಂತರ (ಸೆಕೆಂಡ್‌ಗಳು)"

msgid "Try again later ..."
msgstr "ನಂತರ ಮತ್ತೆ ಪ್ರಯತ್ನಿಸಿ..."

msgid "WELCOME TO FILMON PLUGIN BY LULULLA"
msgstr "ಲುಲುಲ್ಲಾ ಅವರ ಫಿಲ್ಮನ್ ಪ್ಲಗಿನ್‌ಗೆ ಸುಸ್ವಾಗತ"
