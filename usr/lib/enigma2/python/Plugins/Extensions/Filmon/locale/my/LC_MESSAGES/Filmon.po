msgid "Buffering..."
msgstr "အရှိန်မြှင့်နေသည်..."

msgid "Cancel"
msgstr "မလုပ်တော့"

msgid "Cannot find group ID"
msgstr "အဖွဲ့ ID ရှာမတွေ့ပါ။"

msgid "Cannot regenerate stream URL"
msgstr "တိုက်ရိုက်လွှင့် URL ကို ပြန်ထုတ်၍မရပါ။"

msgid "Cannot restore stream connection"
msgstr "တိုက်ရိုက်ချိတ်ဆက်မှုကို ပြန်လည်ရယူ၍မရပါ။"

msgid "Could not get stream token"
msgstr "ထုတ်လွှင့်မှုတိုကင်ကို ရယူ၍မရပါ။"

msgid "Enable Token Update refresh on Player."
msgstr "Player တွင် Token အပ်ဒိတ်ပြန်လည်စတင်ခြင်းကို ဖွင့်ပါ။"

msgid "Enable token auto-refresh"
msgstr "တိုကင်အော်တို-ပြန်လည်စတင်ခြင်းကို ဖွင့်ပါ။"

msgid "Error loading channels"
msgstr "ချန်နယ်များကို ဖွင့်ရာတွင် အမှားအယွင်းရှိသည်။"

msgid "Exit"
msgstr "ထွက်ပေါက်"

msgid "Filmon Settings"
msgstr "Filmon ဆက်တင်များ"

msgid "Maximum reconnection attempts reached"
msgstr "အမြင့်ဆုံး ပြန်လည်ချိတ်ဆက်ရန် ကြိုးပမ်းမှုများ ပြီးပါပြီ။"

msgid "No channels found"
msgstr "ချန်နယ်များ မတွေ့ပါ။"

msgid "OK"
msgstr "အိုကေ"

msgid "Play/pause not supported for this stream"
msgstr "ဤထုတ်လွှင့်မှုအတွက် ဖွင့်/ခေတ္တရပ်ခြင်းကို မပံ့ပိုးပါ။"

msgid "Select stream quality"
msgstr "တိုက်ရိုက်ထုတ်လွှင့်မှု အရည်အသွေးကို ရွေးချယ်ပါ။"

msgid "Session error, try again later ..."
msgstr "ဆက်ရှင် အမှားအယွင်း၊ နောက်မှ ထပ်ကြိုးစားပါ..."

msgid "Set Timer Refresh update Player."
msgstr "Timer Refresh အပ်ဒိတ် Player ကို သတ်မှတ်ပါ။"

msgid "Token refresh interval (seconds)"
msgstr "တိုကင်အား ပြန်လည်စတင်သည့်ကာလ (စက္ကန့်)"

msgid "Try again later ..."
msgstr "နောက်မှ ထပ်ကြိုးစားပါ..."

msgid "WELCOME TO FILMON PLUGIN BY LULULLA"
msgstr "LULULLA မှ FILMON PLUGIN မှကြိုဆိုပါတယ်။"
