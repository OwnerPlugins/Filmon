msgid "Buffering..."
msgstr "Inaakibisha..."

msgid "Cancel"
msgstr "Ghairi"

msgid "Cannot find group ID"
msgstr "Haiwezi kupata kitambulisho cha kikundi"

msgid "Cannot regenerate stream URL"
msgstr "Haiwezi kuzalisha upya URL ya mtiririko"

msgid "Cannot restore stream connection"
msgstr "Haiwezi kurejesha muunganisho wa mtiririko"

msgid "Could not get stream token"
msgstr "Haikuweza kupata tokeni ya mtiririko"

msgid "Enable Token Update refresh on Player."
msgstr "Washa usasishaji wa Usasishaji wa Tokeni kwenye Kichezaji."

msgid "Enable token auto-refresh"
msgstr "Washa uonyeshaji upya wa tokeni"

msgid "Error loading channels"
msgstr "Hitilafu katika kupakia vituo"

msgid "Exit"
msgstr "Utgång"

msgid "Filmon Settings"
msgstr "Mipangilio ya Filamu"

msgid "Maximum reconnection attempts reached"
msgstr "Upeo wa juu zaidi wa majaribio ya kuunganisha upya umefikiwa"

msgid "No channels found"
msgstr "Hakuna vituo vilivyopatikana"

msgid "OK"
msgstr "Sawa"

msgid "Play/pause not supported for this stream"
msgstr "Cheza/sitisha haitumiki kwa mtiririko huu"

msgid "Select stream quality"
msgstr "Chagua ubora wa mtiririko"

msgid "Session error, try again later ..."
msgstr "Hitilafu ya kipindi, jaribu tena baadaye..."

msgid "Set Timer Refresh update Player."
msgstr "Weka Kicheza kusasisha Kisasisho cha Kipima Muda."

msgid "Token refresh interval (seconds)"
msgstr "Muda wa kuonyesha upya ishara (sekunde)"

msgid "Try again later ..."
msgstr "Jaribu tena baadaye..."

msgid "WELCOME TO FILMON PLUGIN BY LULULLA"
msgstr "KARIBU KWENYE PLUGIN YA FILMON BY LULULLA"
