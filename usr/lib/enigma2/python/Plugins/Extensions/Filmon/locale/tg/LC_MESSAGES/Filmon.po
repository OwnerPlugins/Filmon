msgid "Buffering..."
msgstr "Буферӣ..."

msgid "Cancel"
msgstr "Бекор кардан"

msgid "Cannot find group ID"
msgstr "ID-и гурӯҳ ёфт нашуд"

msgid "Cannot regenerate stream URL"
msgstr "URL-и ҷараёнро барқарор кардан мумкин нест"

msgid "Cannot restore stream connection"
msgstr "Пайвасти ҷараёнро барқарор кардан мумкин нест"

msgid "Could not get stream token"
msgstr "Токени ҷараёнро гирифта натавонист"

msgid "Enable Token Update refresh on Player."
msgstr "Дар Player навсозии навсозии аломатро фаъол созед."

msgid "Enable token auto-refresh"
msgstr "Навсозии автоматии аломатро фаъол созед"

msgid "Error loading channels"
msgstr "Хатогӣ ҳангоми боркунии каналҳо"

msgid "Exit"
msgstr "Баромадгоҳ"

msgid "Filmon Settings"
msgstr "Танзимоти филм"

msgid "Maximum reconnection attempts reached"
msgstr "Ба ҳадди аксар кӯшиши пайвастшавӣ расид"

msgid "No channels found"
msgstr "Ягон канал ёфт нашуд"

msgid "OK"
msgstr "ДУРУСТ"

msgid "Play/pause not supported for this stream"
msgstr "Бозӣ/таваффақ барои ин ҷараён дастгирӣ намешавад"

msgid "Select stream quality"
msgstr "Сифати ҷараёнро интихоб кунед"

msgid "Session error, try again later ..."
msgstr "Хатогии сессия, дертар такрор кунед ..."

msgid "Set Timer Refresh update Player."
msgstr "Плеери навсозии Timer Refresh -ро насб кунед."

msgid "Token refresh interval (seconds)"
msgstr "Фосилаи навсозии аломат (сонияҳо)"

msgid "Try again later ..."
msgstr "Баъдтар бори дигар кӯшиш кунед..."

msgid "WELCOME TO FILMON PLUGIN BY LULULLA"
msgstr "ХУШ ОМАДЕД БА ПЛАГИНИ FILMON АЗ ЛУЛУЛЛО"
