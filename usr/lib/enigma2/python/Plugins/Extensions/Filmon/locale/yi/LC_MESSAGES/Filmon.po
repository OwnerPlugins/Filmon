msgid "Buffering..."
msgstr "באַפערן ..."

msgid "Cancel"
msgstr "באָטל מאַכן"

msgid "Cannot find group ID"
msgstr "קען ניט געפֿינען גרופּע ID"

msgid "Cannot regenerate stream URL"
msgstr "קענען ניט רעגענערירן סטרימינג URL"

msgid "Cannot restore stream connection"
msgstr "קענען ניט ומקערן די סטרימינג קשר"

msgid "Could not get stream token"
msgstr "קען נישט באַקומען סטרימינג טאָקען"

msgid "Enable Token Update refresh on Player."
msgstr "געבן טאָקען דערהייַנטיקן דערפרישן אויף פּלייַער."

msgid "Enable token auto-refresh"
msgstr "געבן טאָקען אַוטאָ דערפרישן"

msgid "Error loading channels"
msgstr "טעות לאָודינג טשאַנאַלז"

msgid "Exit"
msgstr "אַרויסגאַנג"

msgid "Filmon Settings"
msgstr "פילמאָן סעטטינגס"

msgid "Maximum reconnection attempts reached"
msgstr "מאַקסימום ריקאַנעקשאַן פרווון ריטשט"

msgid "No channels found"
msgstr "קיין טשאַנאַלז געפונען"

msgid "OK"
msgstr "גוט"

msgid "Play/pause not supported for this stream"
msgstr "שפּיל / פּויזע ניט געשטיצט פֿאַר דעם טייַך"

msgid "Select stream quality"
msgstr "אויסקלייַבן טייַך קוואַליטעט"

msgid "Session error, try again later ..."
msgstr "סעסיע טעות, פּרובירן ווידער שפּעטער ..."

msgid "Set Timer Refresh update Player."
msgstr "שטעלן טיימער רעפרעש דערהייַנטיקן פּלייַער."

msgid "Token refresh interval (seconds)"
msgstr "טאָקען דערפרישן מעהאַלעך (סעקונדן)"

msgid "Try again later ..."
msgstr "פּרוּווט ווידער שפּעטער..."

msgid "WELCOME TO FILMON PLUGIN BY LULULLA"
msgstr "ברוכים הבאים צו פילמאָן פּלוגין דורך LULULLA"
